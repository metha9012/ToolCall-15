{
  "name": "llm-toolcall-test",
  "version": "0.1.0",
  "description": "ToolCall-15 is a visual benchmark dashboard for evaluating LLM tool use.",
  "license": "MIT",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:benchlocal": "tsc -p tsconfig.benchlocal.json && tsc-alias -p tsconfig.benchlocal.json",
    "build:cli": "tsc -p tsconfig.cli.json && tsc-alias -p tsconfig.cli.json",
    "cli": "npm run build:cli && node dist-cli/cli/run.js",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@benchlocal/core": "file:../BenchLocal/packages/benchlocal-core",
    "@benchlocal/sdk": "file:../BenchLocal/packages/benchlocal-sdk",
    "lucide-react": "^1.7.0",
    "next": "latest",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "tsc-alias": "^1.8.10",
    "typescript": "latest"
  }
}
